# Optional: Gaia archive credentials for higher quotas / private uploads.
# Without these, Gaia queries run anonymously (sufficient for ~3M-row jobs).
GAIA_USER=
GAIA_PASSWORD=

# Override default rate limit (requests per second to any single external host).
CAOSP_RATE_LIMIT_RPS=1.0

# User-Agent appended to outbound HTTP requests so VizieR/SIMBAD admins can identify us.
CAOSP_USER_AGENT=caosp-hivel-pipeline/0.1 (mailto:you@example.com)
