# =============================================================================
#                            PRIVACY / SECRETS
# =============================================================================
# .env may contain Gaia/SIMBAD credentials, mail addresses, proxy URLs.
# .env.example IS tracked and shows the schema only.
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
credentials*.json
.netrc

# =============================================================================
#                            PYTHON BUILD / VENV
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
.tox/
.nox/

# =============================================================================
#                       JUPYTER / NOTEBOOK ARTIFACTS
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
#                       IDE / EDITOR / OS
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# =============================================================================
#                       PROJECT DATA (SIZE / REDUNDANCY)
# =============================================================================
# Raw catalogue dumps re-fetchable from public archives.
data/raw/**
!data/raw/.gitkeep
!data/raw/*/.gitkeep

# External downloads (LAMOST 2 GB CSV.gz lives here — DO NOT commit).
data/external/**
!data/external/.gitkeep
!data/external/lamost/.gitkeep

# Intermediate parquet (re-derivable; tens of MB).
data/interim/**
!data/interim/.gitkeep

# ----- data/processed/ -----
# Default: ignore everything (parquet master tables can be tens of MB).
data/processed/**
# But keep the small CSVs that the paper directly cites or references
# as machine-readable supplementary tables.
!data/processed/.gitkeep
!data/processed/final_top_candidates.csv
!data/processed/top_unbound_candidates.csv
!data/processed/top_candidates_final_strict_preliminary.csv
!data/processed/top3_simbad.csv
!data/processed/same_sample_distance_sensitivity.csv
!data/processed/rv_outlier_followup.csv
!data/processed/final_rv_sensitivity.csv

# TAP cache, .partial download markers, anything else transient.
cache/**
!cache/.gitkeep

# Logs may include user paths and timestamps.
logs/**
!logs/.gitkeep
*.log

# =============================================================================
#                       LATEX / MANUSCRIPT BUILD ARTIFACTS
# =============================================================================
# These are generated by `bash build.sh` from the .tex source. The PDF
# is intentionally tracked (so users can read the paper without TeXLive).
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.toc
*.out
*.synctex.gz
*.run.xml
*.bcf

# =============================================================================
#                       FIGURES / FONTS — TRACKED
# =============================================================================
# We DO commit reports/figures/*.pdf and paper/figures/*.{pdf,png}
# because they are generated artefacts the paper depends on.
# (No rule needed; only listing here for clarity.)

# =============================================================================
#                       MISC
# =============================================================================
*.bak
*.tmp
*.orig
.DS_Store
